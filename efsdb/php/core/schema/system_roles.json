{
  "entity": "system_roles",
  "kind": "document",
  "storage": {
    "mime": "application/json; charset=utf-8",
    "logicalPathTemplate": "system/roles/{id}.json",
    "chunkProfiles": {
      "default": {
        "target": 65536
      }
    }
  },
  "fields": {
    "id": { "type": "string", "required": true, "trim": true, "slug": true },
    "name": { "type": "string", "required": true, "trim": true },
    "description": { "type": "string", "default": "", "trim": true },
    "entitlements": { "type": "array", "default": [], "items": { "type": "string", "trim": true } },
    "operatorOnly": { "type": "boolean", "default": false },
    "system": { "type": "boolean", "default": false },
    "createdAt": { "type": "datetime", "auto": "create" },
    "updatedAt": { "type": "datetime", "auto": "update" }
  },
  "indexes": {
    "id": { "source": "id", "kind": "keyword", "searchable": true, "sortable": true },
    "name": { "source": "name", "kind": "text", "searchable": true, "sortable": true },
    "description": { "source": "description", "kind": "text", "searchable": true },
    "entitlements": { "source": "entitlements[]", "kind": "keyword", "facet": true, "filterable": true },
    "operatorOnly": { "source": "operatorOnly", "kind": "boolean", "facet": true, "filterable": true },
    "system": { "source": "system", "kind": "boolean", "facet": true, "filterable": true },
    "createdAt": { "source": "createdAt", "kind": "datetime", "sortable": true },
    "updatedAt": { "source": "updatedAt", "kind": "datetime", "sortable": true }
  },
  "search": {
    "defaultFields": ["id", "name", "description"],
    "mode": "contains_ci"
  },
  "summary": {
    "fields": ["id", "name", "description", "operatorOnly", "system", "updatedAt"]
  }
}
