{
  "entity": "public_workspace_roots",
  "kind": "document",
  "storage": {
    "mime": "application/json; charset=utf-8",
    "logicalPathTemplate": "builder/environments/{root}.json",
    "chunkProfiles": {
      "default": {
        "target": 65536
      }
    }
  },
  "fields": {
    "id": { "type": "string", "required": true, "trim": true },
    "tenantKey": { "type": "string", "required": true, "trim": true, "lowercase": true },
    "root": { "type": "string", "required": true, "trim": true, "enum": ["production", "staging"] },
    "visibility": { "type": "string", "required": true, "enum": ["public", "restricted"] },
    "allowedActualRoles": { "type": "array", "default": [], "items": { "type": "string", "trim": true } },
    "deliveryMode": { "type": "string", "required": true, "enum": ["php-html", "sveltekit-php-adapter"] },
    "enabled": { "type": "boolean", "default": false },
    "createdAt": { "type": "datetime", "auto": "create" },
    "updatedAt": { "type": "datetime", "auto": "update" }
  },
  "indexes": {
    "tenantKey": { "source": "tenantKey", "kind": "keyword", "filterable": true, "searchable": true },
    "root": { "source": "root", "kind": "keyword", "filterable": true, "facet": true, "sortable": true },
    "visibility": { "source": "visibility", "kind": "keyword", "filterable": true, "facet": true },
    "deliveryMode": { "source": "deliveryMode", "kind": "keyword", "filterable": true, "facet": true },
    "enabled": { "source": "enabled", "kind": "boolean", "filterable": true, "facet": true },
    "updatedAt": { "source": "updatedAt", "kind": "datetime", "sortable": true }
  },
  "search": {
    "defaultFields": ["tenantKey", "root"],
    "mode": "contains_ci"
  },
  "summary": {
    "fields": ["id", "tenantKey", "root", "visibility", "deliveryMode", "enabled", "updatedAt"]
  }
}
