{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@contracts/*": ["contracts/*"],
      "@ui/*": ["ui/*"],
      "@utils/*": ["utils/*"]
    },
    "types": ["node", "vite/client"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.svelte",
    "ui/**/*.ts",
    "ui/**/*.svelte",
    "contracts/**/*.ts",
    "utils/**/*.ts",
    "*.ts"
  ]
}
