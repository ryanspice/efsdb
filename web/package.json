{
  "name": "efsdb-web",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "bun run typecheck",
    "build:login": "vite build --config apps/login/vite.config.ts",
    "build:explorer": "vite build --config apps/explorer/vite.config.ts",
    "build:builder": "vite build --config apps/builder/vite.config.ts",
    "build:admin": "vite build --config apps/admin/vite.config.ts",
    "build:window-shell": "vite build --config apps/window-shell/vite.config.ts",
    "build:notifications": "vite build --config apps/notifications/vite.config.ts",
    "build:theme": "vite build --config apps/theme/vite.config.ts",
    "build:create": "vite build --config apps/create/vite.config.ts",
    "build:prompt": "vite build --config apps/prompt/vite.config.ts",
    "build:all": "bun run build:login && bun run build:explorer && bun run build:builder && bun run build:admin && bun run build:window-shell && bun run build:notifications && bun run build:theme && bun run build:create && bun run build:prompt",
    "test:ui": "playwright test --config playwright.config.ts"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-html": "^6.4.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lang-php": "^6.0.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^24.0.0",
    "codemirror": "^6.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
