{
  "name": "phpfs-workspace",
  "private": true,
  "packageManager": "bun@1.2.23",
  "workspaces": [
    "efsdb/php/core",
    "web"
  ],
  "scripts": {
    "dev": "bun run ./scripts/dev.ts",
    "php:serve": "bun run dev",
    "check:php-ini": "bun run ./scripts/php-core.ts -- -d efsdb.process_id=check-php-ini efsdb/php/core/bin/assert_repo_php_ini.php",
    "build:css": "bun run --cwd efsdb/php/core build:css",
    "build:login": "bun run web:build:login",
    "build:explorer": "bun run web:build:explorer",
    "build:builder": "bun run web:build:builder",
    "build:admin": "bun run web:build:admin",
    "build:theme": "bun run web:build:theme",
    "build:window-shell": "bun run web:build:window-shell",
    "build:web": "bun ./scripts/build-web.ts",
    "web:typecheck": "bun run --cwd web typecheck",
    "web:build": "bun run --cwd web build",
    "web:build:login": "bun run --cwd web build:login",
    "web:build:explorer": "bun run --cwd web build:explorer",
    "web:build:builder": "bun run --cwd web build:builder",
    "web:build:admin": "bun run --cwd web build:admin",
    "web:build:theme": "bun run --cwd web build:theme",
    "web:build:window-shell": "bun run --cwd web build:window-shell",
    "web:test:ui": "bun run --cwd web test:ui",
    "check:api": "bun run ./scripts/php-core.ts -- -d efsdb.process_id=check-api efsdb/php/core/bin/apicheck.php",
    "check:auth": "bun run ./scripts/php-core.ts -- -d efsdb.process_id=check-auth efsdb/php/core/bin/authcheck.php",
    "check:conformance:generate": "bun run ./scripts/php-core.ts -- -d efsdb.process_id=conformance-gen efsdb/php/conformance/generate.php",
    "check:conformance": "bun run ./scripts/php-core.ts -- -d efsdb.process_id=conformance-run efsdb/php/conformance/run.php",
    "check": "bun run check:php-ini && bun run check:api && bun run check:auth && bun run check:conformance:generate && bun run check:conformance",
    "tenant-admin-key": "bun run ./scripts/php-core.ts -- -d efsdb.process_id=tenant-admin-key efsdb/php/core/bin/efsdb.php tenant-admin-key",
    "gc": "bun run ./scripts/php-core.ts -- -d efsdb.process_id=manual-gc efsdb/php/core/bin/gc.php",
    "reset": "pwsh -Command \"if (Test-Path '.cache/efsdb/live/data') { Remove-Item -Recurse -Force '.cache/efsdb/live/data' }; $env:EFSDB_DATA_DIR='.cache/efsdb/live/data'; bun run ./scripts/php-core.ts -- efsdb/php/core/bin/efsdb.php init\""
  },
  "dependencies": {
    "baseline-browser-mapping": "^2.10.9",
    "caniuse-lite": "^1.0.30001780"
  }
}
